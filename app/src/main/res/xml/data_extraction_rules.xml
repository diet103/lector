<?xml version="1.0" encoding="utf-8"?>
<!--
    Android 12+. Excluded from both cloud backup and direct device-to-device transfer:

    - the key is Keystore-bound, so a copy on another device can never be decrypted anyway;
    - the reading history is a record of everything read aloud on this phone, and it stays here
      (PLAN §4, privacy).

    Note the SQLite side files: an exclusion naming only the .db can still ship the contents of a
    -wal that has not been checkpointed.
-->
<data-extraction-rules>
    <cloud-backup>
        <exclude domain="sharedpref" path="lector_credentials.xml" />
        <exclude domain="database" path="lector_history.db" />
        <exclude domain="database" path="lector_history.db-wal" />
        <exclude domain="database" path="lector_history.db-shm" />
        <exclude domain="database" path="lector_history.db-journal" />
    </cloud-backup>
    <device-transfer>
        <exclude domain="sharedpref" path="lector_credentials.xml" />
        <exclude domain="database" path="lector_history.db" />
        <exclude domain="database" path="lector_history.db-wal" />
        <exclude domain="database" path="lector_history.db-shm" />
        <exclude domain="database" path="lector_history.db-journal" />
    </device-transfer>
</data-extraction-rules>
